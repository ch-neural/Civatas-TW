# ─── Civatas-TW ───
# Isolates this stack from other Civatas checkouts on the same machine
# (e.g. Civatas-V01) so container names don't collide. Containers become
# civatas-tw-web-1, civatas-tw-api-1, …
COMPOSE_PROJECT_NAME=civatas-tw
DEFAULT_LOCALE=zh-TW
TZ=Asia/Taipei

# ─── Web UI host port ───
# Host port for the Next.js web UI (container port stays 3000).
# Change if 3100 conflicts with another project on your machine.
WEB_PORT=3100

# ─── LLM Configuration ───
# API keys 由 UI「設定 → API 金鑰」輸入，寫入 ap/shared/settings.json。
# 以下全部留空即可；下列變數只供極少數 legacy fallback path 使用，
# 不填就是正常狀態。
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=

# Optional: dual-vendor failover (以 UI 為準；留空即可)
LLM_API_KEY2=
LLM_MODEL2=
LLM_BASE_URL2=

# Provider-specific keys (only the one matching LLM_PROVIDER is required)
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
MOONSHOT_API_KEY=

# ─── Serper (news search) ───
# Required for the news_intelligence pipeline; falls back gracefully if absent.
SERPER_API_KEY=

# ─── Election Database (Postgres) ───
ELECTION_DB_USER=civatas
ELECTION_DB_PASS=civatas2026
